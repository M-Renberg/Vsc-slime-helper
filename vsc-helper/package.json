{
  "name": "slime-helper",
  "displayName": "Slime Helper",
  "description": "Coding buddy, in your face reactions, perfect anime slime.",
  "version": "1.3.2",
  "publisher": "Moth-Coder",
  "repository": {
    "type": "git",
    "url": "https://github.com/M-Renberg/Vsc-slime-helper.git"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vsc-helper.helloWorld",
        "title": "Start Slime Helper"
      },
      {
        "command": "slime.openNotes",
        "title": "Slime: Open Notes"
      },
      {
        "command": "slime.ask",
        "title": "Slime: Ask a question"
      }
    ],
    "configuration": {
      "title": "Slime Helper",
      "properties": {
        "slime.exePath": {
          "type": "string",
          "default": "AUTO",
          "description": "Full path to SlimeHelper.exe. Leave as 'AUTO' to use the version bundled with the extension"
        },
        "slime.aiProvider": {
          "type": "string",
          "enum": [
            "Gemini",
            "Claude"
          ],
          "default": "Gemini",
          "description": "Choose which AI brain the Slime should use."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^9.16.0",
    "mocha": "^11.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.18.0"
  },
  "bin": {
    "slime": "./out/slime-cli.js"
  },
  "overrides": {
    "serialize-javascript": "^6.0.2"
  }
}