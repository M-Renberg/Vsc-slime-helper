<Window x:Class="SlimeHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SlimeHelper" Height="350" Width="250"
        WindowStyle="None"  
        AllowsTransparency="True" 
        Background="Transparent"
        IsHitTestVisible="True"
        Topmost="True" 
        ShowInTaskbar="False">

    <Window.ContextMenu>
        <ContextMenu
            Background="DarkGray"
            HasDropShadow="True"
            BorderBrush="Black"
            BorderThickness="1px"
            Opacity="0.9"
            IsHitTestVisible="True">
            <MenuItem Header="Volume">
                <MenuItem.Icon>
                <TextBlock Text="🔊"/>
                </MenuItem.Icon>
                <MenuItem.Items>
                    <Slider Name="VolumeSlider"
                            Width="100"
                            Minimum="0"
                            Maximum="1"
                            Value="0.5"
                            ValueChanged="VolumeChanged"/>        
                </MenuItem.Items>
            </MenuItem>

            <Separator/>

            <MenuItem Header="View Notes" Click="OnViewNotesClick">
                <MenuItem.Icon>
                    <TextBlock Text="📝"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <MenuItem Header="Skins">
                <MenuItem.Icon>
                    <TextBlock Text="🎨"/>
                </MenuItem.Icon>
                <MenuItem Header="Blue" Click="ChangeSkin" Tag="Default"/>
                <MenuItem Header="Green" Click="ChangeSkin" Tag="Green"/>
                <MenuItem Header="Pink" Click="ChangeSkin" Tag="Pink"/>
            </MenuItem>
            
            <Separator/>

            <MenuItem Header="Settings">
                <MenuItem.Icon>
                    <TextBlock Text="⚙️"/>
                </MenuItem.Icon>

                <MenuItem Header="AI Brain">
                    <MenuItem.Icon>
                        <TextBlock Text="🧠"/>
                    </MenuItem.Icon>
                    <MenuItem Header="Gemini" Click="OnProviderChangeClick" Tag="Gemini" IsCheckable="True" x:Name="GeminiCheck"/>
                    <MenuItem Header="Claude" Click="OnProviderChangeClick" Tag="Claude" IsCheckable="True" x:Name="ClaudeCheck"/>
                </MenuItem>

                <Separator/>

                <MenuItem Header="Set Gemini API Key" Click="OnSetGeminiKeyClick">
                    <MenuItem.Icon>
                        <TextBlock Text="🔑"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Set Claude API Key" Click="OnSetClaudeKeyClick">
                    <MenuItem.Icon>
                        <TextBlock Text="🔑"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <Separator/>

            <MenuItem Header="Shut down Slime" Click="CloseApp">
                <MenuItem.Icon>
                    <TextBlock Text="❌"/>
                </MenuItem.Icon>
            </MenuItem>

        </ContextMenu>
    </Window.ContextMenu>

    <Grid VerticalAlignment="Bottom" Margin="0,0,0,20" IsHitTestVisible="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border
            x:Name="SpeechBubble"
            Grid.Row="0"
            CornerRadius="10"
            Margin="10,0,10,10"
            Padding="12"
            Visibility="Collapsed"
            Background="Beige"
            BorderBrush="Black"
            BorderThickness="1"
            MaxWidth="220"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            IsHitTestVisible="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.4"/>
            </Border.Effect>
            <ScrollViewer 
        VerticalScrollBarVisibility="Auto" 
        MaxHeight="150"
        HorizontalScrollBarVisibility="Disabled">

                <TextBlock
            x:Name="SpeechText"
            Text="Hello Master!"
            TextWrapping="Wrap"
            FontSize="13"
            FontFamily="Segoe UI Semibold"
            TextAlignment="Left"
            Foreground="#222"
            />
            </ScrollViewer>
            <Border.Triggers>
                
            </Border.Triggers>
        </Border>
        <Image x:Name="SlimeImage" 
               Grid.Row="1"
               Source="Images/slime_idle.png"
               Height="150"
               Stretch="Uniform"
               RenderTransformOrigin="0.5, 1.0"
               Opacity="0.6"
               IsHitTestVisible="True">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="SlimeScale" ScaleX="1" ScaleY="1"/>
                    <TranslateTransform Y="0"/>
                </TransformGroup>
            </Image.RenderTransform>
            <Image.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                     From="1.0" To="0.95" Duration="0:0:1.8">
                                <DoubleAnimation.EasingFunction>
                                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>

                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                     From="1.0" To="1.05" Duration="0:0:2.2">
                                <DoubleAnimation.EasingFunction>
                                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                     From="0" To="-3" Duration="0:0:0.8">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Image.Triggers>
        </Image>
    </Grid>
</Window>
