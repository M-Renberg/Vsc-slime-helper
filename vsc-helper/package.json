{
  "name": "slime-helper",
  "displayName": "Slime Helper",
  "description": "A VS Code helper that keeps track of your commits, pushes, errors, warnings, and overall progress.",
  "version": "1.0.4",
  "publisher": "Moth-Coder",
  "repository": {
    "type": "git",
    "url": "https://github.com/M-Renberg/Vsc-slime-helper.git"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vsc-helper.helloWorld",
        "title": "Start Slime Helper"
      }
    ],
    "configuration": {
      "title": "Slime Helper",
      "properties": {
        "slime.exePath": {
          "type": "string",
          "default": "C:\\SlimeHelper\\SlimeHelper.exe",
          "description": "Full path to the SlimeHelper.exe file."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "typescript-eslint": "^8.18.0",
    "eslint": "^9.16.0",
    "typescript": "^5.3.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.8"
  }
}